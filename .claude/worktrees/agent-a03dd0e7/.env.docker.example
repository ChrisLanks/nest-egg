# =============================================================================
# Nest Egg - Docker / Production Environment Configuration
# =============================================================================
# Copy this file to .env.docker and update values for your environment.
# Every setting in backend/app/config.py is listed here for discoverability.
# For production: Replace ALL "CHANGE_ME" values before deploying!
#
# Quick setup:
#   1. cp .env.docker.example .env.docker
#   2. Generate keys: openssl rand -hex 32
#   3. Update all CHANGE_ME values below
#   4. docker-compose --env-file .env.docker up -d
# =============================================================================

# =============================================================================
# CRITICAL SECURITY SETTINGS - MUST CHANGE IN PRODUCTION
# =============================================================================

# Application Environment
# Options: development, staging, production
ENVIRONMENT=production
DEBUG=false  # Set to true only for debugging (exposes Swagger/ReDoc/OpenAPI)

# Database Credentials
POSTGRES_DB=nestegg
POSTGRES_USER=nestegg
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Database URL (constructed from credentials above — adjust host for your Docker network)
DATABASE_URL=postgresql+asyncpg://nestegg:CHANGE_ME_GENERATE_STRONG_PASSWORD@db:5432/nestegg  # pragma: allowlist secret
# DB_ECHO=false                # Log every SQL statement (noisy — useful for debugging)
# DB_POOL_SIZE=20              # Connection pool size (increase to 50-100 for high traffic)
# DB_MAX_OVERFLOW=10           # Max overflow connections beyond pool size

# Redis
REDIS_URL=redis://redis:6379/0

# Security Keys (Generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
MASTER_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ENCRYPTION_CURRENT_VERSION=1   # Increment to 2 when rotating
#
# --- Rotation procedure ---
# 1. Generate a new Fernet key:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 2. Move current MASTER_ENCRYPTION_KEY -> ENCRYPTION_KEY_V1 below
# 3. Set MASTER_ENCRYPTION_KEY = <new key>
# 4. Increment ENCRYPTION_CURRENT_VERSION (e.g. 1 -> 2)
# 5. Deploy — old V1 rows decrypt fine; new writes use new version prefix
#
# Previous key — decryption only after rotation (leave unset on first deploy):
# ENCRYPTION_KEY_V1=<previous MASTER_ENCRYPTION_KEY value here>

# Allowed Hosts (CRITICAL for production - specific domains only!)
# Example: app.nestegg.com,api.nestegg.com
# NEVER use "*" in production - the app will reject this value
ALLOWED_HOSTS=app.yourdomain.com,api.yourdomain.com

# CORS Origins (Update for production to specific frontend domains)
# Example: https://app.nestegg.com,https://www.nestegg.com
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# =============================================================================
# AUTHENTICATION
# =============================================================================
# ACCESS_TOKEN_EXPIRE_MINUTES=15   # Short-lived JWT (industry standard)
# REFRESH_TOKEN_EXPIRE_DAYS=30     # Long-lived refresh token
# MAX_LOGIN_ATTEMPTS=5             # Failed attempts before account lockout
# ACCOUNT_LOCKOUT_MINUTES=30       # Duration of lockout after max failed attempts

# =============================================================================
# API KEYS - Required for Core Functionality
# =============================================================================

# Plaid (Financial Data Aggregation)
# Sign up at: https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox  # Options: sandbox, development, production
PLAID_WEBHOOK_SECRET=your_plaid_webhook_secret
PLAID_ENABLED=true

# Teller (Alternative Financial Aggregation - 100 free accounts/month)
# Sign up at: https://teller.io
TELLER_APP_ID=your_teller_app_id
TELLER_API_KEY=your_teller_api_key
TELLER_ENV=sandbox  # Options: sandbox, production
TELLER_WEBHOOK_SECRET=your_teller_webhook_secret
TELLER_ENABLED=true
# mTLS certificate issued by Teller (download from Teller dashboard).
# Required for production Teller API calls; not needed in sandbox mode.
# Mount the certificate into the container and set the path here.
# TELLER_CERT_PATH=/app/certs/teller-certificate.pem

# =============================================================================
# OPTIONAL - MX Platform API (Enterprise Bank Linking)
# =============================================================================
# Requires enterprise sales contract — disabled by default
# Sandbox: https://int-api.mx.com — Production: https://api.mx.com
# MX_CLIENT_ID=your_mx_client_id
# MX_API_KEY=your_mx_api_key
# MX_ENV=sandbox
MX_ENABLED=false

# =============================================================================
# OPTIONAL - Market Data (Investment Prices)
# =============================================================================
# Provider for live stock/ETF/fund prices.
# Options: yahoo_finance (default, free, no key), alpha_vantage, finnhub
MARKET_DATA_PROVIDER=yahoo_finance

# How many hours before holding prices are considered stale (throttles refreshes).
# PRICE_REFRESH_COOLDOWN_HOURS=6

# Alpha Vantage (500 calls/day free)
# Sign up at: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Finnhub (60 calls/min free)
# Sign up at: https://finnhub.io/register
# FINNHUB_API_KEY=your_finnhub_key

# =============================================================================
# OPTIONAL - Property Auto-Valuation
# =============================================================================
# Set one or more provider keys to enable the "Refresh Valuation" button.
# When multiple are set, the UI lets the user choose; the first configured
# provider is used when none is specified explicitly.

# RentCast (rentcast.io) — RECOMMENDED
# Free tier: 50 calls/month (permanent, no credit card required).
# Sign up: https://app.rentcast.io/app/api-access
# RENTCAST_API_KEY=your_rentcast_api_key

# ATTOM Data Solutions (attomdata.com)
# Paid (30-day trial). Sign up: https://api.gateway.attomdata.com
# ATTOM_API_KEY=your_attom_api_key

# Zillow via RapidAPI (NOT RECOMMENDED — may violate Zillow ToS)
# Sign up: https://rapidapi.com/apimaker/api/zillow-com1
# ZILLOW_RAPIDAPI_KEY=your_zillow_rapidapi_key

# =============================================================================
# OPTIONAL - Vehicle Auto-Valuation
# =============================================================================
# MarketCheck (marketcheck.com) — KBB-comparable used-car valuations via VIN.
# NHTSA (nhtsa.dot.gov) is always used for free VIN decode (year/make/model).
# MARKETCHECK_API_KEY=your_marketcheck_api_key

# =============================================================================
# BACKGROUND TASKS (Celery)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Sync intervals
# PLAID_SYNC_INTERVAL_HOURS=6            # How often Celery syncs Plaid accounts
# RULE_APPLICATION_INTERVAL_HOURS=1      # How often auto-categorization rules run
# MAX_MANUAL_SYNCS_PER_HOUR=1            # Rate limit for user-triggered syncs
# SYNC_INITIAL_DAYS=90                   # Days of history to fetch on first sync
# SYNC_INCREMENTAL_DAYS=7                # Days of history on incremental syncs
# SYNC_MAX_RETRIES=3                     # Retry count for failed syncs
# SYNC_RETRY_DELAY_SECONDS=300           # Seconds between retries (5 minutes)

# Flower Web UI Credentials (Access at http://localhost:5555)
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# PAGINATION
# =============================================================================
# DEFAULT_PAGE_SIZE=50   # Items per page when client omits page_size
# MAX_PAGE_SIZE=200      # Hard upper limit on page_size param

# =============================================================================
# EMAIL / SMTP (Optional)
# =============================================================================
# All optional — emails are silently skipped when SMTP_HOST is unset.
# Works with any SMTP provider: Gmail, AWS SES, SendGrid, Mailgun, etc.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=app-password-here
# SMTP_FROM_EMAIL=noreply@nestegg.app
# SMTP_FROM_NAME=Nest Egg
# SMTP_USE_TLS=true                # Use STARTTLS (port 587). Set false for SSL on port 465.

# Base URL used to build clickable links in emails (e.g. password reset).
# In production, set to your public frontend URL.
# APP_BASE_URL=https://app.yourdomain.com

# =============================================================================
# FILE STORAGE (CSV Uploads, Attachments)
# =============================================================================
# "local" stores files on disk (dev-friendly default)
# "s3" stores files in AWS S3 (recommended for production / multi-container)
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=/app/uploads
# --- S3 settings (only needed when STORAGE_BACKEND=s3) ---
# Leave AWS_ACCESS_KEY_ID unset to use the EC2/ECS IAM instance role (recommended in prod)
# AWS_S3_BUCKET=my-nestegg-uploads
# AWS_REGION=us-east-1
# AWS_S3_PREFIX=csv-uploads/
# AWS_ACCESS_KEY_ID=AKIA...          # omit to use IAM role
# AWS_SECRET_ACCESS_KEY=...          # omit to use IAM role

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Logging
LOG_LEVEL=INFO   # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: text, json (json recommended for production)

# Prometheus metrics are served on a SEPARATE admin port (not the main API port).
# Access: curl -u admin:<password> http://localhost:9090/metrics
METRICS_ENABLED=true
METRICS_ADMIN_PORT=9090
METRICS_USERNAME=admin
METRICS_PASSWORD=CHANGE_ME_SECURE_METRICS_PASSWORD
# METRICS_INCLUDE_IN_SCHEMA=false   # Hide /metrics from Swagger docs

# Sentry Error Tracking (Recommended for production)
# Sign up at: https://sentry.io
# SENTRY_DSN=your_sentry_dsn

# =============================================================================
# COMPLIANCE & DATA RETENTION
# =============================================================================
TERMS_VERSION=2026-02  # Bump this when Terms of Service or Privacy Policy changes

# Data retention — enterprise compliance feature.
# Unset = keep data indefinitely (default for self-hosted / small teams).
# DATA_RETENTION_DAYS=365
# Safety: dry-run logs what would be deleted without actually deleting.
# Set to false only after verifying the retention window is correct.
# DATA_RETENTION_DRY_RUN=true

# =============================================================================
# IDENTITY PROVIDER CHAIN (SSO)
# =============================================================================
# Ordered comma-separated list of active providers.
# 'builtin' = app's own HS256 JWT (always available as fallback).
# First provider whose JWT issuer/alg matches the incoming token wins.
#
# Examples:
#   IDENTITY_PROVIDER_CHAIN=builtin                     <- dev default
#   IDENTITY_PROVIDER_CHAIN=cognito,builtin             <- Cognito + fallback
#   IDENTITY_PROVIDER_CHAIN=keycloak,okta,google,builtin
IDENTITY_PROVIDER_CHAIN=builtin

# --- AWS Cognito (add 'cognito' to IDENTITY_PROVIDER_CHAIN to enable) ---
# Pool HTTPS endpoint from the AWS Cognito console.
# IDP_COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
# IDP_COGNITO_CLIENT_ID=your_cognito_app_client_id
# IDP_COGNITO_ADMIN_GROUP=nest-egg-admins   # Cognito group -> org admin

# --- Keycloak (add 'keycloak' to IDENTITY_PROVIDER_CHAIN to enable) ---
# IDP_KEYCLOAK_ISSUER=https://keycloak.example.com/realms/nest-egg
# IDP_KEYCLOAK_CLIENT_ID=nest-egg
# IDP_KEYCLOAK_ADMIN_GROUP=nest-egg-admins
# IDP_KEYCLOAK_GROUPS_CLAIM=groups          # JWT claim that contains group list

# --- Okta (add 'okta' to IDENTITY_PROVIDER_CHAIN to enable) ---
# IDP_OKTA_ISSUER=https://company.okta.com/oauth2/default
# IDP_OKTA_CLIENT_ID=your_okta_client_id
# IDP_OKTA_GROUPS_CLAIM=groups

# --- Google (add 'google' to IDENTITY_PROVIDER_CHAIN to enable) ---
# Paste the "Web application" client ID from the Google Cloud Console.
# IDP_GOOGLE_CLIENT_ID=your_google_oauth2_client_id.apps.googleusercontent.com

# =============================================================================
# FRONTEND
# =============================================================================

# Frontend API URL (Backend API endpoint as seen by the frontend)
# For production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# Frontend Port (Default: 80)
FRONTEND_PORT=80

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying to production, verify:
#
# [ ] All CHANGE_ME values replaced with secure values
# [ ] SECRET_KEY and MASTER_ENCRYPTION_KEY generated with: openssl rand -hex 32
# [ ] POSTGRES_PASSWORD is strong (16+ chars, mixed case, numbers, symbols)
# [ ] ALLOWED_HOSTS set to specific domains (NOT "*")
# [ ] CORS_ORIGINS set to specific domains (NOT "http://localhost:*")
# [ ] ENVIRONMENT=production
# [ ] DEBUG=false
# [ ] LOG_FORMAT=json
# [ ] METRICS_PASSWORD is secure (not default)
# [ ] Plaid/Teller API keys from production accounts
# [ ] VITE_API_URL points to production backend domain
# [ ] APP_BASE_URL points to production frontend domain
# [ ] FLOWER_PASSWORD is secure
# [ ] (Optional) SENTRY_DSN configured for error tracking
# [ ] (Optional) SMTP configured for email notifications
# [ ] SSL/TLS certificates configured (use reverse proxy like nginx or Traefik)
# =============================================================================
